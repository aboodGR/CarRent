@model CarRent.Models.Rental

@{
    ViewData["Title"] = "Rental Details";
}

<h2>Rental Details</h2>

<div>
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.RentalId</dd>

        <dt class="col-sm-2">Customer</dt>
        <dd class="col-sm-10">@Model.Customer?.FullName</dd>

        <dt class="col-sm-2">Car</dt>
        <dd class="col-sm-10">@Model.Car?.Brand - @Model.Car?.Model</dd>

        <dt class="col-sm-2">Start Date</dt>
        <dd class="col-sm-10">@Model.StartDate.ToShortDateString()</dd>

        <dt class="col-sm-2">End Date</dt>
        <dd class="col-sm-10">@Model.EndDate.ToShortDateString()</dd>

        <dt class="col-sm-2">Total Price</dt>
        <dd class="col-sm-10">@Model.TotalPrice</dd>
    </dl>
</div>

<a asp-action="Edit" asp-route-id="@Model.RentalId" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
