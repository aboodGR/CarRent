@model CarRent.Models.Rental

<h2>Edit Rental</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="RentalId" />

    <div class="form-group">
        <label>Customer</label>
        <select asp-for="CustomerId"
                class="form-control"
                asp-items="ViewBag.Customers">
        </select>
    </div>

    <div class="form-group">
        <label>Car</label>
        <select asp-for="CarId"
                class="form-control"
                asp-items="ViewBag.Cars">
        </select>
    </div>

    <div class="form-group">
        <label asp-for="StartDate"></label>
        <input asp-for="StartDate" class="form-control" type="date" />
    </div>

    <div class="form-group">
        <label asp-for="EndDate"></label>
        <input asp-for="EndDate" class="form-control" type="date" />
    </div>

    <div class="form-group">
        <label asp-for="TotalPrice"></label>
        <input asp-for="TotalPrice" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
</form>

