@model CarRent.Models.Car

@{
    ViewData["Title"] = "Car Details";
}

<h2>Car Details</h2>

<div>
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.CarId</dd>

        <dt class="col-sm-2">Brand</dt>
        <dd class="col-sm-10">@Model.Brand</dd>

        <dt class="col-sm-2">Model</dt>
        <dd class="col-sm-10">@Model.Model</dd>

        <dt class="col-sm-2">Year</dt>
        <dd class="col-sm-10">@Model.Year</dd>

        <dt class="col-sm-2">Rental Type</dt>
        <dd class="col-sm-10">@Model.RentalType</dd>

        <dt class="col-sm-2">Price/Day</dt>
        <dd class="col-sm-10">@Model.PricePerDay</dd>
    </dl>
</div>

<a asp-action="Edit" asp-route-id="@Model.CarId" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
