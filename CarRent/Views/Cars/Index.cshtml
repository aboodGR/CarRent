@model IEnumerable<CarRent.Models.Car>

@{
    ViewData["Title"] = "Cars";
}

<h2>Cars</h2>

<!-- Search and Sort Form -->
<form method="get" class="mb-3">
    <input name="search"
           value="@Context.Request.Query["search"]"
           class="form-control"
           placeholder="Search by brand" />

    <select name="sort" class="form-select mt-2">
        <option value="">Sort by Brand (A–Z)</option>
        <option value="price_asc">Year : Low to high</option>
        <option value="price_desc">Year : High to Loe</option>
    </select>

    <button class="btn btn-primary mt-2">Apply</button>
</form>


<!-- Table view -->
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Brand</th>
            <th>Model</th>
            <th>Year</th>
            <th>Rental Type</th>
            <th>Price/Day</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var car in Model)
        {
            <tr>
                <td>@car.CarId</td>
                <td>@car.Brand</td>
                <td>@car.Model</td>
                <td>@car.Year</td>
                <td>@car.RentalType</td>
                <td>@car.PricePerDay.ToString("C")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@car.CarId" class="btn btn-primary btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@car.CarId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@car.CarId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<!-- Cards view using partial -->
<div class="row mt-4">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-3">
            <partial name="_CarCard" model="item" />
        </div>
    }
</div>

<a asp-action="Create" class="btn btn-success mt-3">Add New Car</a>
